:{"text":"porque espero verte en breve, y hablaremos cara a cara. La paz sea contigo. Los amigos te saludan. Saluda tú a los amigos por nombre.","segments":[{"text":"porque","strong":"G1161","morph":"C"},{"text":"espero","strong":"G1679","morph":"VPAI1S"},{"text":"verte","strong":"G4571","morph":"VAAN"},{"text":"en"},{"text":"breve,","strong":"G2112","morph":"B"},{"text":"y","strong":"G2532","morph":"C"},{"text":"hablaremos","strong":"G2980","morph":"VFAI1P"},{"text":"cara","strong":"G4750","morph":"NASN"},{"text":"a","strong":"G4314","morph":"P"},{"text":"cara.","strong":"G4750","morph":"NASN"},{"text":"La"},{"text":"paz","strong":"G1515","morph":"NNSF"},{"text":"sea"},{"text":"contigo.","strong":"G4671","morph":"RP2DS"},{"text":"Los","strong":"G3588","morph":"DNPM"},{"text":"amigos","strong":"G5384","morph":"JNPM"},{"text":"te","strong":"G4571","morph":"RP2AS"},{"text":"saludan.","strong":"G782","morph":"VPUI3P"},{"text":"Saluda","strong":"G782","morph":"VPUM2S"},{"text":"tú"},{"text":"a"},{"text":"los","strong":"G3588","morph":"DAPM"},{"text":"amigos","strong":"G5384","morph":"JAPM"},{"text":"por"},{"text":"nombre."}],"strongs":["G1161","G1515","G1679","G2112","G2532","G2980","G3588","G4314","G4571","G4671","G4750","G5384","G782"]}}}}