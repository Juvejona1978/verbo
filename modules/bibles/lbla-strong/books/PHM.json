uego que","morph":"CAP","strong":"G3704"},{"text":"la","morph":"DNSF","strong":"G3588"},{"text":"comunión","morph":"NNSF","strong":"G2842"},{"text":"de tu","morph":"RP2GS","strong":"G4675"},{"text":"fe","morph":"DGSF"},{"text":"llegue a ser","morph":"VAMS3S","strong":"G1096"},{"text":"eficaz","morph":"JNSF","strong":"G1756"},{"text":"por","morph":"P","strong":"G1722"},{"text":"el conocimiento","morph":"NDSF","strong":"G1922"},{"text":"de todo","morph":"JGSN","strong":"G3956"},{"text":"lo bueno","morph":"JGSN","strong":"G18"},{"text":"que","morph":"DGSN","strong":"G3588"},{"text":"hay en","morph":"P","strong":"G1722"},{"text":"vosotros","morph":"RP1DP","strong":"G2254"},{"text":"mediante","morph":"P","strong":"G1519"},{"text":"Cristo","morph":"NASM","strong":"G5547"},{"text":"."}]},"7":{"text":"Pues he llegado a tener mucho gozo y consuelo en tu amor, porque los corazones de los santos han sido confortados por ti, hermano.","segments":[{"text":"Pues","morph":"CLX","strong":"G1063"},{"text":"he llegado","morph":"VAAI1S","strong":"G2192"},{"text":"a tener mucho","morph":"JASF","strong":"G4183"},{"text":"gozo","morph":"NASF","strong":"G5479"},{"text":"y","morph":"CLN","strong":"G2532"},{"text":"consuelo","morph":"NASF","strong":"G3874"},{"text":"en","morph":"P","strong":"G1909"},{"text":"tu","morph":"RP2GS","strong":"G4675"},{"text":"amor","morph":"DDSF"},{"text":", porque","morph":"CAZ","strong":"G3754"},{"text":"los","morph":"DNPN","strong":"G3588"},{"text":"corazones","morph":"NNPN","strong":"G4698"},{"text":"de los","morph":"DGPM","strong":"G3588"},{"text":"santos","morph":"JGPM","strong":"G40"},{"text":"han sido confortados","morph":"VRPI3S","strong":"G373"},{"text":"por","morph":"P","strong":"G1223"},{"text":"ti","morph":"RP2GS","strong":"G4675"},{"text":", hermano","morph":"NVSM","strong":"G80"},{"text":"."}]},"8":{"text":"¶ Por lo cual, aunque tengo mucha libertad en Cristo para mandarte hacer lo que conviene,","segments":[{"text":"¶ Por","morph":"CLI","strong":"G1352"},{"text":"lo cual, aunque tengo","morph":"VPAP-SNM","strong":"G2192"},{"text":"mucha","morph":"JASF","strong":"G4183"},{"text":"libertad","morph":"NASF","strong":"G3954"},{"text":"en","morph":"P","strong":"G1722"},{"text":"Cristo","morph":"NDSM","strong":"G5547"},{"text":"para mandarte","morph":"VPAN"},{"text":"hacer lo","morph":"DASN","strong":"G3588"},{"text":"que conviene","morph":"VPAP-SAN","strong":"G433"},{"text":","}]},"9":{"text":"no obstante, por causa del amor que te tengo, te ruego, siendo como soy, Pablo, anciano, y ahora también prisionero de Cristo Jesús,","segments":[{"text":"no","morph":"B","strong":"G3123"},{"text":"obstante, por","morph":"P","strong":"G1223"},{"text":"causa del","morph":"DASF","strong":"G3588"},{"text":"amor","morph":"NASF","strong":"G26"},{"text":"que te tengo, te ruego","morph":"VPAI1S","strong":"G3870"},{"text":", siendo","morph":"VPAP-SNM","strong":"G5607"},{"text":"como","morph":"RD-NSM","strong":"G5108"},{"text":"soy,","morph":"P"},{"text":"Pablo","morph":"NNSM","strong":"G3972"},{"text":", anciano","morph":"NNSM","strong":"G4246"},{"text":", y","morph":"CLC","strong":"G1161"},{"text":"ahora","morph":"B","strong":"G3570"},{"text":"también","morph":"BE"},{"text":"prisionero","morph":"NNSM","strong":"G1198"},{"text":"de Cristo","morph":"NGSM","strong":"G5547"},{"text":"Jesús","morph":"NGSM","strong":"G2424"},{"text":","}]},"10":{"text":"te ruego por mi hijo Onésimo, a quien he engendrado en mis prisiones,","segments":[{"text":"te","morph":"RP2AS","strong":"G4571"},{"text":"ruego","morph":"VPAI1S","strong":"G3870"},{"text":"por","morph":"P","strong":"G4012"},{"text":"mi","morph":"JGSN"},{"text":"hijo","morph":"DGSN"},{"text":"Onésimo","morph":"NASM","strong":"G3682"},{"text":", a quien","morph":"RR-ASM","strong":"G3739"},{"text":"he engendrado","morph":"VAAI1S","strong":"G1080"},{"text":"en","morph":"P","strong":"G1722"},{"text":"mis prisiones","morph":"DDPM"},{"text":","}]},"11":{"text":"el cual en otro tiempo te era inútil, pero ahora nos es útil a ti y a mí.","segments":[{"text":"el","morph":"DASM","strong":"G3588"},{"text":"cual en","morph":"BX"},{"text":"otro tiempo te","morph":"RP2DS","strong":"G4671"},{"text":"era inútil","morph":"JASM","strong":"G890"},{"text":", pero","morph":"CLC","strong":"G1161"},{"text":"ahora","morph":"BK","strong":"G3570"},{"text":"nos es útil","morph":"JASM","strong":"G2173"},{"text":"a ti","morph":"RP2DS","strong":"G4671"},{"text":"y","morph":"CLK"},{"text":"a mí","morph":"RP1DS","strong":"G1698"},{"text":"."}]},"12":{"text":"Y te lo he vuelto a enviar en persona, es decir, como si fuera mi propio corazón,","segments":[{"text":"Y","morph":"RR-ASM","strong":"G3739"},{"text":"te","morph":"RP2DS","strong":"G4671"},{"text":"lo","morph":"RP3ASM","strong":"G846"},{"text":"he vuelto","morph":"VAAI1S","strong":"G375"},{"text":"a enviar en persona, es","morph":"VPAI3S","strong":"G2076"},{"text":"decir","morph":"RD-NSN","strong":"G5124"},{"text":", como si fuera mi propio","morph":"DNPN"},{"text":"corazón","morph":"NNPN","strong":"G4698"},{"text":","}]},"13":{"text":"a quien • hubiera querido retener conmigo, para que me sirviera en lugar tuyo en mis prisiones por el evangelio;","segments":[{"text":"a quien","morph":"RR-ASM","strong":"G3739"},{"text":"•","morph":"RP1NS","strong":"G1473"},{"text":"hubiera querido","morph":"VIUI1S","strong":"G1014"},{"text":"retener","morph":"VPAN","strong":"G2722"},{"text":"conmigo","morph":"P"},{"text":", para","morph":"CAP","strong":"G2443"},{"text":"que me","morph":"RP1DS","strong":"G3427"},{"text":"sirviera","morph":"VPAS3S","strong":"G1247"},{"text":"en","morph":"P","strong":"G5228"},{"text":"lugar tuyo","morph":"RP2GS","strong":"G4675"},{"text":"en","morph":"P","strong":"G1722"},{"text":"mis prisiones","morph":"DDPM"},{"text":"por el","morph":"DGSN","strong":"G3588"},{"text":"evangelio","morph":"NGSN","strong":"G2098"},{"text":";"}]},"14":{"text":"pero no quise hacer nada sin tu consentimiento, para que tu bondad no fuera como por obligación, sino por tu propia voluntad.","segments":[{"text":"pero","morph":"CLC","strong":"G1161"},{"text":"no","morph":"JASN","strong":"G3762"},{"text":"quise","morph":"VAAI1S","strong":"G2309"},{"text":"hacer","morph":"VAAN","strong":"G4160"},{"text":"nada sin","morph":"P"},{"text":"tu","morph":"DGSF"},{"text":"consentimiento","morph":"NGSF","strong":"G1106"},{"text":", para","morph":"CAP","strong":"G2443"},{"text":"que tu","morph":"RP2GS","strong":"G4675"},{"text":"bondad","morph":"DNSN"},{"text":"no","morph":"BN"},{"text":"fuera","morph":"VPAS3S","strong":"G5600"},{"text":"como","morph":"CAM"},{"text":"por","morph":"P","strong":"G2596"},{"text":"obligación","morph":"NASF","strong":"G318"},{"text":", sino","morph":"CLC","strong":"G235"},{"text":"por","morph":"P","strong":"G2596"},{"text":"tu propia voluntad","morph":"JASN","strong":"G1595"},{"text":"."}]},"15":{"text":"Porque quizá por esto se apartó de ti por algún tiempo, para que lo volvieras a recibir para siempre,","segments":[{"text":"Porque","morph":"CLX","strong":"G1063"},{"text":"quizá","morph":"B","strong":"G5029"},{"text":"por","morph":"P","strong":"G1223"},{"text":"esto","morph":"RD-ASN","strong":"G5124"},{"text":"se apartó","morph":"VAPI3S","strong":"G5563"},{"text":"de ti por","morph":"P","strong":"G4314"},{"text":"algún tiempo","morph":"NASF","strong":"G5610"},{"text":", para","morph":"CAP","strong":"G2443"},{"text":"que lo","morph":"RP3ASM","strong":"G846"},{"text":"volvieras","morph":"VPAS2S","strong":"G568"},{"text":"a recibir para siempre","morph":"JASM","strong":"G166"},{"text":","}]},"16":{"text":"no ya como esclavo, sino como más que un esclavo, como un hermano amado, especialmente para mí, pero cuánto más para ti, tanto en la carne como en el Señor.","segments":[{"text":"no","morph":"BN","strong":"G3765"},{"text":"ya como","morph":"P"},{"text":"esclavo","morph":"NASM","strong":"G1401"},{"text":", sino","morph":"CLC","strong":"G235"},{"text":"como más","morph":"P","strong":"G5228"},{"text":"que un esclavo","morph":"NASM","strong":"G1401"},{"text":", como un hermano","morph":"NASM","strong":"G80"},{"text":"amado","morph":"JASM","strong":"G27"},{"text":", especialmente","morph":"BS","strong":"G3122"},{"text":"para mí","morph":"RP1DS","strong":"G1698"},{"text":", pero","morph":"CLC","strong":"G1161"},{"text":"cuánto","morph":"RI-DSN","strong":"G4214"},{"text":"más","morph":"B","strong":"G3123"},{"text":"para ti","morph":"RP2DS","strong":"G4671"},{"text":", tanto","morph":"CLK","strong":"G2532"},{"text":"en","morph":"P","strong":"G1722"},{"text":"la carne","morph":"NDSF","strong":"G4561"},{"text":"como","morph":"CLK"},{"text":"en","morph":"P","strong":"G1722"},{"text":"el Señor","morph":"NDSM","strong":"G2962"},{"text":"."}]},"17":{"text":"Si me tienes pues por compañero, acéptalo como me aceptarías a mí.","segments":[{"text":"Si","morph":"CAC","strong":"G1487"},{"text":"me","morph":"RP1AS","strong":"G3165"},{"text":"tienes","morph":"VPAI2S","strong":"G2192"},{"text":"pues","morph":"CLI","strong":"G3767"},{"text":"por compañero","morph":"JASM"},{"text":", acéptalo","morph":"VAMM2S"},{"text":"como","morph":"CAM","strong":"G5613"},{"text":"me aceptarías a mí","morph":"RP1AS","strong":"G1691"},{"text":"."}]},"18":{"text":"Y si te ha perjudicado en alguna forma, o te debe algo, cárgalo a mi cuenta.","segments":[{"text":"Y","morph":"CLN","strong":"G1161"},{"text":"si","morph":"CAC","strong":"G1487"},{"text":"te","morph":"RP2AS","strong":"G4571"},{"text":"ha perjudicado","morph":"VAAI3S","strong":"G91"},{"text":"en alguna","morph":"RX-ASN","strong":"G5100"},{"text":"forma, o","morph":"CLD","strong":"G2228"},{"text":"te debe","morph":"VPAI3S","strong":"G3784"},{"text":"algo, cárgalo","morph":"RD-ASN"},{"text":"a mi","morph":"RP1DS","strong":"G1698"},{"text":"cuenta."}]},"19":{"text":"Yo, Pablo, escribo esto con mi propia mano; yo lo pagaré (por no decirte que aun tú mismo te me debes a mí ).","segments":[{"text":"Yo","morph":"RP1NS","strong":"G1473"},{"text":", Pablo","morph":"NNSM","strong":"G3972"},{"text":", escribo","morph":"VAAI1S","strong":"G1125"},{"text":"esto con mi propia","morph":"DDSF"},{"text":"mano","morph":"NDSF","strong":"G5495"},{"text":"; yo","morph":"RP1NS","strong":"G1473"},{"text":"lo pagaré","morph":"VFAI1S","strong":"G661"},{"text":"(por","morph":"CAP","strong":"G2443"},{"text":"no","morph":"BN"},{"text":"decirte","morph":"VPAS1S"},{"text":"que","morph":"CSC","strong":"G3754"},{"text":"aun","morph":"BE"},{"text":"tú mismo","morph":"RF2ASM","strong":"G4572"},{"text":"te me debes","morph":"VPAI2S","strong":"G4359"},{"text":"a mí","morph":"RP1DS","strong":"G3427"},{"text":")."}]},"20":{"text":"Sí, hermano, permíteme disfrutar este beneficio • de ti en el Señor; recrea mi corazón en Cristo.","segments":[{"text":"Sí","morph":"I"},{"text":", hermano","morph":"NVSM","strong":"G80"},{"text":", permíteme disfrutar este beneficio","morph":"VAMO1S","strong":"G3685"},{"text":"•","morph":"RP1NS","strong":"G1473"},{"text":"de ti","morph":"RP2GS","strong":"G4675"},{"text":"en","morph":"P","strong":"G1722"},{"text":"el Señor","morph":"NDSM","strong":"G2962"},{"text":"; recrea","morph":"VAAM2S","strong":"G373"},{"text":"mi","morph":"RP1GS","strong":"G3450"},{"text":"corazón","morph":"DAPN"},{"text":"en","morph":"P","strong":"G1722"},{"text":"Cristo","morph":"NDSM","strong":"G5547"},{"text":"."}]},"21":{"text":"¶ Te escribo confiado en tu obediencia, sabiendo que harás aun más de lo que digo.","segments":[{"text":"¶ Te","morph":"RP2DS","strong":"G4671"},{"text":"escribo","morph":"VAAI1S","strong":"G1125"},{"text":"confiado","morph":"VRAP-SNM","strong":"G3982"},{"text":"en tu","morph":"RP2GS","strong":"G4675"},{"text":"obediencia","morph":"DDSF"},{"text":", sabiendo","morph":"VRAP-SNM","strong":"G1492"},{"text":"que","morph":"CSC","strong":"G3754"},{"text":"harás","morph":"VFAI2S","strong":"G4160"},{"text":"aun","morph":"BE"},{"text":"más","morph":"P","strong":"G5228"},{"text":"de lo que","morph":"RR-APN","strong":"G3739"},{"text":"digo","morph":"VPAI1S","strong":"G3004"},{"text":"."}]},"22":{"text":"Y al mismo tiempo, prepárame • también alojamiento, pues espero que por vuestras oraciones os seré concedido.","segments":[{"text":"Y","morph":"B","strong":"G260"},{"text":"al mismo tiempo, prepárame","morph":"VPAM2S"},{"text":"•","morph":"CLN","strong":"G1161"},{"text":"también","morph":"BE"},{"text":"alojamiento","morph":"NASF","strong":"G3578"},{"text":", pues","morph":"CAZ","strong":"G1063"},{"text":"espero","morph":"VPAI1S","strong":"G1679"},{"text":"que","morph":"CSC","strong":"G3754"},{"text":"por","morph":"P","strong":"G1223"},{"text":"vuestras","morph":"RP2GP","strong":"G5216"},{"text":"oraciones","morph":"DGPF"},{"text":"os","morph":"RP2DP","strong":"G5213"},{"text":"seré concedido","morph":"VFPI1S","strong":"G5483"},{"text":"."}]},"23":{"text":"¶ Te saluda Epafras, mi compañero de prisión en Cristo Jesús;","segments":[{"text":"¶ Te","morph":"RP2AS","strong":"G4571"},{"text":"saluda","morph":"VPUI3S","strong":"G782"},{"text":"Epafras","morph":"NNSM","strong":"G1889"},{"text":", mi","morph":"RP1GS","strong":"G3450"},{"text":"compañero","morph":"DNSM"},{"text":"de prisión en","morph":"P","strong":"G1722"},{"text":"Cristo","morph":"NDSM","strong":"G5547"},{"text":"Jesús","morph":"NDSM","strong":"G2424"},{"text":";"}]},"24":{"text":"también Marcos, Aristarco, Demas y Lucas, mis colaboradores.","segments":[{"text":"también Marcos","morph":"NNSM","strong":"G3138"},{"text":", Aristarco","morph":"NNSM","strong":"G708"},{"text":", Demas","morph":"NNSM","strong":"G1214"},{"text":"y Lucas","morph":"NNSM","strong":"G3065"},{"text":", mis","morph":"RP1GS","strong":"G3450"},{"text":"colaboradores","morph":"DNPM"},{"text":"."}]},"25":{"text":"¶ La gracia del Señor Jesucristo sea con vuestro espíritu.","segments":[{"text":"¶ La","morph":"DNSF","strong":"G3588"},{"text":"gracia","morph":"NNSF","strong":"G5485"},{"text":"del","morph":"DGSM","strong":"G3588"},{"text":"Señor","mor