576"},{"text":"con","morph":"P"},{"text":"cadenas","morph":"A"},{"text":"."}]},"11":{"text":"Tú también quedarás embriagada, estarás escondida; tú también buscarás refugio del enemigo.","segments":[{"text":"Tú","morph":"RP2FS","strong":"H859"},{"text":"también","morph":"D","strong":"H1571"},{"text":"quedarás embriagada","morph":"VaI2FS","strong":"H7937"},{"text":", estarás","morph":"VaI3FS-J","strong":"H1961"},{"text":"escondida","morph":"VdR-FSA","strong":"H5956"},{"text":"; tú","morph":"RP2FS","strong":"H859"},{"text":"también","morph":"D","strong":"H1571"},{"text":"buscarás","morph":"VbI2FS","strong":"H1245"},{"text":"refugio","morph":"NC-SA","strong":"H4581"},{"text":"del","morph":"P","strong":"H4481"},{"text":"enemigo","morph":"NCMSA","strong":"H341"},{"text":"."}]},"12":{"text":"Todas tus fortalezas son • higueras cargadas • de brevas; si se sacuden, caen en la boca de quien las va a comer.","segments":[{"text":"Todas","morph":"NC-SC","strong":"H3605"},{"text":"tus","morph":"RS2FS","strong":"H859"},{"text":"fortalezas","morph":"NCMPC","strong":"H4013"},{"text":"son • higueras","morph":"NCMPA","strong":"H8384"},{"text":"cargadas • de","morph":"P","strong":"H5973"},{"text":"brevas","morph":"NCMPA","strong":"H1061"},{"text":"; si","morph":"C","strong":"H518"},{"text":"se sacuden","morph":"VdI3MP","strong":"H5128"},{"text":",","morph":"C"},{"text":"caen","morph":"Vap3-P","strong":"H5307"},{"text":"en","morph":"P","strong":"H5921"},{"text":"la boca","morph":"NC-SC","strong":"H6310"},{"text":"de quien las va a comer","morph":"VaR-MSA","strong":"H398"},{"text":"."}]},"13":{"text":"He aquí a • tu pueblo: sólo • mujeres en medio de ti. A tus enemigos se abren de par en parlas puertas de tu tierra; el fuego devora tus cerrojos.","segments":[{"text":"He aquí","morph":"X","strong":"H2009"},{"text":"a • tu","morph":"RS2FS","strong":"H859"},{"text":"pueblo","morph":"NC-SC","strong":"H5971"},{"text":": sólo • mujeres","morph":"NCMPA","strong":"H802"},{"text":"en","morph":"P"},{"text":"medio","morph":"NC-SC","strong":"H7130"},{"text":"de ti","morph":"RS2FS","strong":"H859"},{"text":". A","morph":"P"},{"text":"tus","morph":"RS2FS","strong":"H859"},{"text":"enemigos","morph":"NCMPC","strong":"H341"},{"text":"se abren","morph":"VdP3-P","strong":"H6605"},{"text":"de","morph":"VaF---A","strong":"H6605"},{"text":"par en parlas puertas","morph":"NCMPC","strong":"H8179"},{"text":"de tu","morph":"RS2FS","strong":"H859"},{"text":"tierra","morph":"NC-SC","strong":"H776"},{"text":"; el fuego","morph":"NC-SA","strong":"H784"},{"text":"devora","morph":"VaP3FS","strong":"H398"},{"text":"tus","morph":"RS2FS","strong":"H859"},{"text":"cerrojos","morph":"NCMPC","strong":"H1280"},{"text":"."}]},"14":{"text":"Abastécete de agua para el asedio, refuerza tus fortalezas, métete en el lodo y pisa el barro, toma el molde de ladrillos.","segments":[{"text":"Abastécete","morph":"VaM2FS","strong":"H7579"},{"text":"de agua","morph":"NCMPC","strong":"H4325"},{"text":"para","morph":"P"},{"text":"el","morph":"RS2FS","strong":"H859"},{"text":"asedio","morph":"NC-SA","strong":"H4692"},{"text":", refuerza","morph":"VbM2FS","strong":"H2388"},{"text":"tus","morph":"RS2FS","strong":"H859"},{"text":"fortalezas","morph":"NCMPC","strong":"H4013"},{"text":", métete","morph":"VaM2FS","strong":"H935"},{"text":"en","morph":"P"},{"text":"el","morph":"A"},{"text":"lodo","morph":"NC-SA","strong":"H2916"},{"text":"y","morph":"C"},{"text":"pisa","morph":"VaM2FS","strong":"H7429"},{"text":"el","morph":"A"},{"text":"barro","morph":"NC-SA","strong":"H2563"},{"text":", toma","morph":"VcM2FS","strong":"H2388"},{"text":"el molde","morph":"NC-SA","strong":"H4404"},{"text":"de ladrillos."}]},"15":{"text":"Allí te consumirá el fuego, te destruirá la espada, te devorará como el pulgón. Multiplícate como el pulgón, multiplícate como la langosta.","segments":[{"text":"Allí","morph":"D","strong":"H8033"},{"text":"te","morph":"RS2FS","strong":"H859"},{"text":"consumirá","morph":"VaI3FS","strong":"H398"},{"text":"el fuego","morph":"NC-SA","strong":"H784"},{"text":", te","morph":"RS2FS","strong":"H859"},{"text":"destruirá","morph":"VcI3FS","strong":"H3772"},{"text":"la espada","morph":"NC-SA","strong":"H2719"},{"text":", te","morph":"RS2FS","strong":"H859"},{"text":"devorará","morph":"VaI3FS","strong":"H398"},{"text":"como","morph":"P"},{"text":"el","morph":"A"},{"text":"pulgón","morph":"NC-SA","strong":"H3218"},{"text":". Multiplícate","morph":"VgM2MS","strong":"H3513"},{"text":"como","morph":"P"},{"text":"el","morph":"A"},{"text":"pulgón","morph":"NC-SA","strong":"H3218"},{"text":", multiplícate","morph":"VgM2FS","strong":"H3513"},{"text":"como","morph":"P"},{"text":"la","morph":"A"},{"text":"langosta","morph":"NC-SA","strong":"H697"},{"text":"."}]},"16":{"text":"Has multiplicado tus mercaderes más • que las estrellas del cielo; el pulgón despoja y vuela.","segments":[{"text":"Has multiplicado","morph":"VcP2FS","strong":"H7235"},{"text":"tus","morph":"RS2FS","strong":"H859"},{"text":"mercaderes","morph":"VaR-MPC","strong":"H7402"},{"text":"más • que","morph":"P","strong":"H4481"},{"text":"las estrellas","morph":"NCMPC","strong":"H3556"},{"text":"del","morph":"A"},{"text":"cielo","morph":"NCMPA","strong":"H8064"},{"text":"; el pulgón","morph":"NC-SA","strong":"H3218"},{"text":"despoja","morph":"VaP3MS","strong":"H6584"},{"text":"y","morph":"C"},{"text":"vuela","morph":"VaW3MS","strong":"H5774"},{"text":"."}]},"17":{"text":"Tus oficiales son • como la langosta, tus jefes como nubes de langostas posados sobre las tapias en un día de frío; sale el sol, y se van, y no se sabe donde están.","segments":[{"text":"Tus","morph":"RS2FS","strong":"H859"},{"text":"oficiales","morph":"NCMPC","strong":"H4502"},{"text":"son • como","morph":"P"},{"text":"la","morph":"A"},{"text":"langosta","morph":"NC-SA","strong":"H697"},{"text":",","morph":"C"},{"text":"tus","morph":"RS2FS","strong":"H859"},{"text":"jefes","morph":"NCMPC","strong":"H2951"},{"text":"como","morph":"P"},{"text"