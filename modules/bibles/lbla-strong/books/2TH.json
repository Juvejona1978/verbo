ros","morph":"RP1NP","strong":"G2249"},{"text":"siempre","morph":"B","strong":"G3842"},{"text":"tenemos","morph":"VPAI1P","strong":"G3784"},{"text":"que dar gracias","morph":"VPAN","strong":"G2168"},{"text":"a Dios","morph":"DDSM"},{"text":"por","morph":"P","strong":"G4012"},{"text":"vosotros","morph":"RP2GP","strong":"G5216"},{"text":", hermanos","morph":"NVPM","strong":"G80"},{"text":"amados","morph":"VRPP-PNM","strong":"G25"},{"text":"por","morph":"P","strong":"G5259"},{"text":"el Señor","morph":"NGSM","strong":"G2962"},{"text":", porque","morph":"CAZ","strong":"G3754"},{"text":"Dios","morph":"DNSM"},{"text":"os","morph":"RP2AP","strong":"G5209"},{"text":"ha escogido","morph":"VAMI3S","strong":"G138"},{"text":"desde el principio","morph":"NASF","strong":"G536"},{"text":"para","morph":"P","strong":"G1519"},{"text":"salvación","morph":"NASF","strong":"G4991"},{"text":"mediante","morph":"P","strong":"G1722"},{"text":"la santificación","morph":"NDSM","strong":"G38"},{"text":"por el Espíritu","morph":"NGSN","strong":"G4151"},{"text":"y","morph":"CLN","strong":"G2532"},{"text":"la fe","morph":"NDSF","strong":"G4102"},{"text":"en la verdad","morph":"NGSF","strong":"G225"},{"text":"."}]},"14":{"text":"Y fue para esto que El os llamó mediante nuestro evangelio, para que alcancéis la gloria de nuestro Señor Jesucristo.","segments":[{"text":"Y fue para","morph":"P","strong":"G1519"},{"text":"esto","morph":"RR-ASN","strong":"G3739"},{"text":"que El os","morph":"RP2AP","strong":"G5209"},{"text":"llamó","morph":"VAAI3S","strong":"G2564"},{"text":"mediante","morph":"P","strong":"G1223"},{"text":"nuestro","morph":"RP1GP","strong":"G2257"},{"text":"evangelio","morph":"DGSN"},{"text":", para","morph":"P","strong":"G1519"},{"text":"que alcancéis","morph":"NASF","strong":"G4047"},{"text":"la gloria","morph":"NGSF","strong":"G1391"},{"text":"de nuestro","morph":"RP1GP","strong":"G2257"},{"text":"Señor","morph":"DGSM"},{"text":"Jesucristo","morph":"NGSM"},{"text":"."}]},"15":{"text":"