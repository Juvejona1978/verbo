:"G1680"},{"text":"por","morph":"P","strong":"G1722"},{"text":"gracia","morph":"NDSF","strong":"G5485"},{"text":","}]},"17":{"text":"consuele vuestros corazones y os afirme en toda obra y palabra buena.","segments":[{"text":"consuele","morph":"VAAO3S","strong":"G3870"},{"text":"vuestros","morph":"RP2GP","strong":"G5216"},{"text":"corazones","morph":"DAPF"},{"text":"y","morph":"CLN","strong":"G2532"},{"text":"os afirme","morph":"VAAO3S","strong":"G4741"},{"text":"en","morph":"P","strong":"G1722"},{"text":"toda","morph":"JDSN"},{"text":"obra","morph":"NDSN","strong":"G2041"},{"text":"y","morph":"CLN","strong":"G2532"},{"text":"palabra","morph":"NDSM","strong":"G3056"},{"text":"buena","morph":"JDSN","strong":"G18"},{"text":"."}]}},"3":{"1":{"text":"Finalmente, hermanos, orad por nosotros, para que la palabra del Señor se extienda rápidamente y sea glorificada, así como sucedió también con vosotros;","segments":[{"text":"Finalmente","morph":"DASN"},{"text":", hermanos","morph":"NVPM","strong":"G80"},{"text":", orad","morph":"VPUM2P","strong":"G4336"},{"text":"por","morph":"P","strong":"G4012"},{"text":"nosotros","morph":"RP1GP","strong":"G2257"},{"text":", para","morph":"CSC","strong":"G2443"},{"text":"que la","morph":"DNSM","strong":"G3588"},{"text":"palabra","morph":"NNSM","strong":"G3056"},{"text":"del","morph":"DGSM","strong":"G3588"},{"text":"Señor","morph":"NGSM","strong":"G2962"},{"text":"se extienda rápidamente","morph":"VPAS3S","strong":"G5143"},{"text":"y","morph":"CLN","strong":"G2532"},{"text":"sea glorificada","morph":"VPPS3S","strong":"G1392"},{"text":", así","morph":"CAM","strong":"G2531"},{"text":"como sucedió también","morph":"BE"},{"text":"con","morph":"P","strong":"G4314"},{"text":"vosotros","morph":"RP2AP","strong":"G5209"},{"text":";"}]},"2":{"text":"y para que seamos librados de hombres perversos y malos, porque no todos tienen fe.","segments":[{"text":"y","morph":"CLN","strong":"G2532"},{"text":"para","morph":"CSC","strong":"G2443"},{"text":"que seamos librados","morph":"VAPS1P","strong":"G4506"},{"text":"de","morph":"P","strong":"G575"},{"text":"hombres","morph":"DGPM"},{"text":"perversos","morph":"JGPM","strong":"G824"},{"text":"y","morph":"CLN","strong":"G2532"},{"text":"malos","morph":"JGPM","strong":"G4190"},{"text":", porque","morph":"CAZ","strong":"G1063"},{"text":"no","morph":"BN"},{"text":"todos","morph":"JGPM","strong":"G3956"},{"text":"tienen fe","morph":"DNSF"},{"text":"."}]},"3":{"text":"Pero fiel es el Señor quien os fortalecerá y protegerá del maligno.","segments":[{"text":"Pero","morph":"CLC","strong":"G1161"},{"text":"fiel","morph":"JNSM","strong":"G4103"},{"text":"es","morph":"VPAI3S","strong":"G2076"},{"text":"el","morph":"DNSM","strong":"G3588"},{"text":"Señor","morph":"NNSM","strong":"G2962"},{"text":"quien","morph":"RR-NSM","strong":"G3739"},{"text":"os","morph":"RP2AP","strong":"G5209"},{"text":"fortalecerá","morph":"VFAI3S","strong":"G4741"},{"text":"y","morph":"CLN","strong":"G2532"},{"text":"protegerá","morph":"VFAI3S","strong":"G5442"},{"text":"del","morph":"P"},{"text":"maligno","morph":"JGSM","strong":"G4190"},{"text":"."}]},"4":{"text":"Y tenemos confianza en el Señor respecto de vosotros, de que • hacéis y haréis lo que ordenamos.","segments":[{"text":"Y","morph":"CLN","strong":"G1161"},{"text":"tenemos confianza","morph":"VRAI1P","strong":"G3982"},{"text":"en","morph":"P","strong":"G1722"},{"text":"el Señor","morph":"NDSM","strong":"G2962"},{"text":"respecto","morph":"P","strong":"G1909"},{"text":"de vosotros","morph":"RP2AP","strong":"G5209"},{"text":", de que","morph":"CSC","strong":"G3754"},{"text":"•","morph":"CLK","strong":"G2532"},{"text":"hacéis","morph":"VPAI2P","strong":"G4160"},{"text":"y","morph":"CLK"},{"text":"haréis","morph":"VFAI2P","strong":"G4160"},{"text":"lo","morph":"RR-APN","strong":"G3739"},{"text":"que ordenamos","morph":"VPAI1P","strong":"G3853"},{"text":"."}]},"5":{"text":"Que el Señor dirija vuestros corazones hacia el amor de Dios y hacia la perseverancia de Cristo.","segments":[{"text":"Que","morph":"CLN","strong":"G1161"},{"text":"el","morph":"DNSM","strong":"G3588"},{"text":"Señor","morph":"NNSM","strong":"G2962"},{"text":"dirija","morph":"VAAO3S","strong":"G2720"},{"text":"vuestros","morph":"RP2GP","strong":"G5216"},{"text":"corazones","morph":"DAPF"},{"text":"hacia","morph":"P","strong":"G1519"},{"text":"el","morph":"DASF","strong":"G3588"},{"text":"amor","morph":"NASF","strong":"G26"},{"text":"de Dios","morph":"DGSM"},{"text":"y","morph":"CLN","strong":"G2532"},{"text":"hacia","morph":"P","strong":"G1519"},{"text":"la","morph":"DASF","strong":"G3588"},{"text":"perseverancia","morph":"NASF","strong":"G5281"},{"text":"de Cristo","morph":"DGSM"},{"text":"."}]},"6":{"text":"¶ Ahora bien, hermanos, os mandamos en el nombre de nuestro Señor Jesucristo, que os apartéis de todo hermano que ande desordenadamente, y no según la doctrina que recibisteis de nosotros.","segments":[{"text":"¶ Ahora","morph":"CLT","strong":"G1161"},{"text":"bien, hermanos","morph":"NVPM","strong":"G80"},{"text":", os","morph":"RP2DP","strong":"G5213"},{"text":"mandamos","morph":"VPAI1P","strong":"G3853"},{"text":"en","morph":"P","strong":"G1722"},{"text":"el nombre","morph":"NDSN","strong":"G3686"},{"text":"de nuestro","morph":"RP1GP","strong":"G2257"},{"text":"Señor","morph":"DGSM"},{"text":"Jesucristo","morph":"NGSM"},{"text":", que os","morph":"RP2AP","strong":"G5209"},{"text":"apartéis","morph":"VPMN","strong":"G4724"},{"text":"de","morph":"P","strong":"G575"},{"text":"todo","morph":"JGSM","strong":"G3956"},{"text":"hermano","morph":"NGSM","strong":"G80"},{"text":"que ande","morph":"VPAP-SGM","strong":"G4043"},{"text":"desordenadamente","morph":"B","strong":"G814"},{"text":", y","morph":"CLN","strong":"G2532"},{"text":"no","morph":"BN"},{"text":"según","morph":"P","strong":"G2596"},{"text":"la","morph":"DASF","strong":"G3588"},{"text":"doctrina","morph":"NASF","strong":"G3862"},{"text":"que","morph":"RR-ASF","strong":"G3739"},{"text":"recibisteis","morph":"VAAI3P","strong":"G3880"},{"text":"de","morph":"P","strong":"G3844"},{"text":"nosotros","morph":"RP1GP","strong":"G2257"},{"text":"."}]},"7":{"text":"Pues vosotros mismos sabéis cómo debéis seguir nuestro ejemplo, porque no obramos de manera indisciplinada entre vosotros,","segments":[{"text":"Pues","morph":"CAZ","strong":"G1063"},{"text":"vosotros mismos","morph":"RP3NPMP","strong":"G846"},{"text":"sabéis","morph":"VRAI2P","strong":"G1492"},{"text":"cómo","morph":"B","strong":"G4459"},{"text":"debéis","morph":"VPAI3S","strong":"G1163"},{"text":"seguir nuestro","morph":"RP1AP","strong":"G2248"},{"text":"ejemplo","morph":"VPUN","strong":"G3401"},{"text":", porque","morph":"CAZ","strong":"G3754"},{"text":"no","morph":"CLK"},{"text":"obramos de manera indisciplinada","morph":"VAAI1P","strong":"G812"},{"text":"entre","morph":"P","strong":"G1722"},{"text":"vosotros","morph":"RP2DP","strong":"G5213"},{"text":","}]},"8":{"text":"ni comimos de balde el pan de nadie, sino que con trabajo y fatiga trabajamos día y noche a fin de no ser carga a ninguno de vosotros;","segments":[{"text":"ni","morph":"TN"},{"text":"comimos","morph":"VAAI1P","strong":"G5315"},{"text":"de balde","morph":"B","strong":"G1432"},{"text":"el pan","morph":"NASM","strong":"G740"},{"text":"de","morph":"P","strong":"G3844"},{"text":"nadie","morph":"RX-GSM","strong":"G5100"},{"text":", sino","morph":"CLK"},{"text":"que con","morph":"P","strong":"G1722"},{"text":"trabajo","morph":"NDSM","strong":"G2873"},{"text":"y","morph":"CLN","strong":"G2532"},{"text":"fatiga","morph":"NDSM","strong":"G3449"},{"text":"trabajamos","morph":"VPUP-PNM","strong":"G2038"},{"text":"día","morph":"NGSF","strong":"G3571"},{"text":"y","morph":"CLN","strong":"G2532"},{"text":"noche","morph":"NGSF","strong":"G2250"},{"text":"a","morph":"P","strong":"G4314"},{"text":"fin de no","morph":"BN"},{"text":"ser carga","morph":"DASN"},{"text":"a ninguno","morph":"RX-ASM","strong":"G5100"},{"text":"de vosotros","morph":"RP2GP","strong":"G5216"},{"text":";"}]},"9":{"text":"no porque no tengamos derecho a ello, sino para ofrecernos como modelo a vosotros a fin de que sigáis nuestro ejemplo.","segments":[{"text":"no","morph":"CLK"},{"text":"porque","morph":"CAZ","strong":"G3754"},{"text":"no","morph":"CLK"},{"text":"tengamos","morph":"VPAI1P","strong":"G2192"},{"text":"derecho","morph":"NASF","strong":"G1849"},{"text":"a ello, sino","morph":"CLK"},{"text":"para","morph":"CAP","strong":"G2443"},{"text":"ofrecernos","morph":"RF3APM"},{"text":"como modelo","morph":"NASM","strong":"G5179"},{"text":"a vosotros","morph":"RP2DP","strong":"G5213"},{"text":"a","morph":"P","strong":"G1519"},{"text":"fin de que sigáis","morph":"DASN"},{"text":"nuestro","morph":"RP1AP","strong":"G2248"},{"text":"ejemplo."}]},"10":{"text":"Porque aun cuando estábamos con vosotros os ordenábamos esto • Si alguno no quiere trabajar, que tampoco coma.","segments":[{"text":"Porque","morph":"CLX","strong":"G1063"},{"text":"aun","morph":"CLA"},{"text":"cuando","morph":"CAT","strong":"G3753"},{"text":"estábamos","morph":"VIAI1P","strong":"G1510"},{"text":"con","morph":"P","strong":"G4314"},{"text":"vosotros","morph":"RP2AP","strong":"G5209"},{"text":"os","morph":"RP2DP","strong":"G5213"},{"text":"ordenábamos","morph":"VIAI1P","strong":"G3853"},{"text":"esto","morph":"RD-ASN","strong":"G5124"},{"text":"•","morph":"CSC","strong":"G3754"},{"text":"Si","morph":"CAC","strong":"G1487"},{"text":"alguno","morph":"RX-NSM","strong":"G5100"},{"text":"no","morph":"BN"},{"text":"quiere","morph":"VPAI3S","strong":"G2309"},{"text":"trabajar","morph":"VPUN","strong":"G2038"},{"text":", que tampoco","morph":"BN"},{"text":"coma","morph":"VPAM3S","strong":"G2068"},{"text":"."}]},"11":{"text":"Porque oímos que algunos entre vosotros andan desordenadamente, sin trabajar, pero andan metiéndose en todo.","segments":[{"text":"Porque","morph":"CAZ","strong":"G1063"},{"text":"oímos","morph":"VPAI1P","strong":"G191"},{"text":"que algunos","morph":"RX-APM","strong":"G5100"},{"text":"entre","morph":"P","strong":"G1722"},{"text":"vosotros","morph":"RP2DP","strong":"G5213"},{"text":"andan","morph":"VPAP-PAM","strong":"G4043"},{"text":"desordenadamente","morph":"B","strong":"G814"},{"text":", sin","morph":"JASN","strong":"G3367"},{"text":"trabajar","morph":"VPUP-PAM","strong":"G2038"},{"text":", pero","morph":"CLC","strong":"G235"},{"text":"andan metiéndose","morph":"VPUP-PAM","strong":"G4020"},{"text":"en todo."}]},"12":{"text":"A tales personas les ordenamos y exhortamos en el Señor Jesucristo, que trabajando tranquilamente, coman su propio pan.","segments":[{"text":"A","morph":"CLN","strong":"G1161"},{"text":"tales","morph":"DDPM"},{"text":"personas les ordenamos","morph":"VPAI1P","strong":"G3853"},{"text":"y","morph":"CLN","strong":"G2532"},{"text":"exhortamos","morph":"VPAI1P","strong":"G3870"},{"text":"en","morph":"P","strong":"G1722"},{"text":"el Señor","morph":"NDSM","strong":"G2962"},{"text":"Jesucristo","morph":"NDSM"},{"text":", que","morph":"CSC","strong":"G2443"},{"text":"trabajando","morph":"VPUP-PNM","strong":"G2038"},{"text":"tranquilamente","morph":"P"},{"text":", coman","morph":"VPAS3P","strong":"G2068"},{"text":"su propio","morph":"DASM"},{"text":"pan","morph":"NASM","strong":"G740"},{"text":"."}]},"13":{"text":"Pero vosotros, hermanos, no os canséis de hacer el bien.","segments":[{"text":"Pero","morph":"CLC","strong":"G1161"},{"text":"vosotros","morph":"RP2NP","strong":"G5210"},{"text":", hermanos","morph":"NVPM","strong":"G80"},{"text":", no","morph":"BN"},{"text":"os canséis","morph":"VAAS2P","strong":"G1573"},{"text":"de hacer","morph":"VPAP-PNM","strong":"G2569"},{"text":"el bien."}]},"14":{"text":"Y si alguno no obedece nuestra enseñanza en esta carta, señalad al tal y no os asociéis con él, para que se avergüence.","segments":[{"text":"Y","morph":"CLN","strong":"G1161"},{"text":"si","morph":"CAC","strong":"G1487"},{"text":"alguno","morph":"RX-NSM","strong":"G5100"},{"text":"no","morph"