88"},{"text":"espíritu","morph":"NDSN","strong":"G4151"},{"text":"de su","morph":"RP3GSM","strong":"G846"},{"text":"boca","morph":"DGSN"},{"text":", y","morph":"CLN","strong":"G2532"},{"text":"destruirá","morph":"VFAI3S","strong":"G2673"},{"text":"con","morph":"NDSF","strong":"G2015"},{"text":"el","morph":"DDSF","strong":"G3588"},{"text":"resplandor de su","morph":"RP3GSM","strong":"G846"},{"text":"venida","morph":"DGSF"},{"text":";"}]},"9":{"text":"inicuo cuya venida es conforme a la actividad de Satanás, con todo poder y señales y prodigios mentirosos,","segments":[{"text":"inicuo cuya","morph":"RR-GSM","strong":"G3739"},{"text":"venida","morph":"DNSF"},{"text":"es","morph":"VPAI3S","strong":"G2076"},{"text":"conforme","morph":"P","strong":"G2596"},{"text":"a la actividad","morph":"NASF","strong":"G1753"},{"text":"de Satanás","morph":"DGSM"},{"text":", con","morph":"P","strong":"G1722"},{"text":"todo","morph":"JDSF","strong":"G3956"},{"text":"poder","morph":"NDSF","strong":"G1411"},{"text":"y","morph":"CLN","strong":"G2532"},{"text":"señales","morph":"NDPN","strong":"G4592"},{"text":"y","morph":"CLN","strong":"G2532"},{"text":"prodigios","morph":"NDPN","strong":"G5059"},{"text":"mentirosos","morph":"NGSN","strong":"G5579"},{"text":","}]},"10":{"text":"y con todo engaño de iniquidad para los que se pierden, porque no recibieron el amor de la verdad para ser salvos •.","segments":[{"text":"y","morph":"CLN","strong":"G2532"},{"text":"con","morph":"P","strong":"G1722"},{"text":"todo","morph":"JDSF","strong":"G3956"},{"text":"engaño","morph":"NDSF","strong":"G539"},{"text":"de iniquidad","morph":"NGSF","strong":"G93"},{"text":"para los","morph":"DDPM","strong":"G3588"},{"text":"que se pierden","morph":"VPUP-PDM","strong":"G622"},{"text":", porque","morph":"P"},{"text":"no","morph":"BN"},{"text":"recibieron","morph":"VAMI3P","strong":"G1209"},{"text":"el","morph":"DASF","strong":"G3588"},{"text":"amor","morph":"NASF","strong":"G26"},{"text":"de la","morph":"DGSF","stron