rong":"H2720"},{"text":"?"}]},"5":{"text":"Ahora pues, así dice el Señor de los ejércitos: Considerad bien vuestros caminos.","segments":[{"text":"Ahora","morph":"D","strong":"H6258"},{"text":"pues","morph":"C"},{"text":", así","morph":"D","strong":"H3541"},{"text":"dice","morph":"VaP3MS","strong":"H559"},{"text":"el Señor","morph":"NPMSA","strong":"H3068"},{"text":"de los ejércitos","morph":"NCFPA","strong":"H6635"},{"text":": Considerad bien","morph":"VaM2MP"},{"text":"vuestros","morph":"RS2MP","strong":"H859"},{"text":"caminos","morph":"NCMPC","strong":"H1870"},{"text":"."}]},"6":{"text":"Sembráis mucho, pero recogéis poco; coméis, pero no hay suficiente • para que os saciéis; bebéis, pero no hay suficiente • para que os embriaguéis; os vestís, pero nadie se calienta; y el que recibe salario, recibe salario en bolsa rota.","segments":[{"text":"Sembráis","morph":"VaP2MP","strong":"H2232"},{"text":"mucho","morph":"D","strong":"H7235"},{"text":", pero","morph":"C"},{"text":"recogéis","morph":"VcF---A","strong":"H935"},{"text":"poco","morph":"NC-SA","strong":"H4592"},{"text":"; coméis","morph":"VaF---A","strong":"H398"},{"text":", pero","morph":"C"},{"text":"no","morph":"NC-SC","strong":"H369"},{"text":"hay suficiente • para","morph":"P"},{"text":"que os saciéis","morph":"NCFSA","strong":"H7654"},{"text":"; bebéis","morph":"VaF---A","strong":"H8354"},{"text":", pero","morph":"C"},{"text":"no","morph":"NC-SC","strong":"H369"},{"text":"hay suficiente • para","morph":"P"},{"text":"que os embriaguéis","morph":"VaF---C","strong":"H7937"},{"text":"; os vestís","morph":"VaF---A","strong":"H3847"},{"text":", pero","morph":"C"},{"text":"nadie","morph":"NC-SC","strong":"H369"},{"text":"se","morph":"P"},{"text":"calienta","morph":"P"},{"text":"; y","morph":"C"},{"text":"el","morph":"A"},{"text":"que recibe salario","morph":"VgR-MSA","strong":"H7939"},{"text":", recibe salario","morph":"VgR-MSA","strong":"H7939"},{"text":"en","morph":"P","strong":"H413"},{"text":"bolsa","morph":"NC-SA","strong":"H6872"},{"text":"rota","morph":"VaS-MSA","strong":"H5344"},{"text":"."}]},"7":{"text":"Así dice el Señor de los ejércitos: Considerad bien vuestros caminos.","segments":[{"text":"Así","morph":"D","strong":"H3541"},{"text":"dice","morph":"VaP3MS","strong":"H559"},{"text":"el Señor","morph":"NPMSA","strong":"H3068"},{"text":"de los ejércitos","morph":"NCFPA","strong":"H6635"},{"text":": Considerad bien","morph":"VaM2MP"},{"text":"vuestros","morph":"RS2MP","strong":"H859"},{"text":"caminos","morph":"NCMPC","strong":"H1870"},{"text":"."}]},"8":{"text":"Subid al monte, traed madera y reedificad el templo, para que me agrade de él y yo sea glorificado —dice el Señor.","segments":[{"text":"Subid","morph":"VaM2MP","strong":"H5927"},{"text":"al","morph":"A"},{"text":"monte","morph":"NC-SA","strong":"H2022"},{"text":",","morph":"C"},{"text":"traed","morph":"Vcp2MP","strong":"H935"},{"text":"madera","morph":"NC-SA","strong":"H6086"},{"text":"y","morph":"C"},{"text":"reedificad","morph":"VaM2MP","strong":"H1129"},{"text":"el","morph":"A"},{"text":"templo","morph":"NC-SA","strong":"H1004"},{"text":", para","morph":"C"},{"text":"que me agrade","morph":"Vaw1-S","strong":"H7521"},{"text":"de","morph":"P"},{"text":"él","morph":"RS3MS","strong":"H1931"},{"text":"y","morph":"C"},{"text":"yo sea glorificado","morph":"Vdw1-S","strong":"H3513"},{"text":"—dice","morph":"VaP3MS","strong":"H559"},{"text":"el Señor","morph":"NPMSA","strong":"H3068"},{"text":"."}]},"9":{"text":"Esperáis mucho, pero he aquí, hay • poco; y lo • que • traéis a casa, yo lo aviento. ¿Por qué? —declara el Señor de los ejércitos —. Por causa de mi casa que está desolada, mientras cada uno de • vosotros corre a su casa.","segments":[{"text":"Esperáis","morph":"VaF---A","strong":"H6437"},{"text":"mucho","morph":"D","strong":"H7235"},{"text":", pero","morph":"C"},{"text":"he","morph":"X","strong":"H2009"},{"text":"aquí, hay • poco","morph":"P"},{"text":"; y","morph":"C"},{"text":"lo • que • traéis","m