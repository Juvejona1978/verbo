,"strong":"G4571"},{"text":"dejé","morph":"VAAI1S","strong":"G620"},{"text":"en","morph":"P","strong":"G1722"},{"text":"Creta","morph":"NDSF","strong":"G2914"},{"text":", para","morph":"CAP","strong":"G2443"},{"text":"que pusieras","morph":"VAMS2S","strong":"G1930"},{"text":"en orden lo","morph":"DAPN","strong":"G3588"},{"text":"que queda","morph":"VPAP-PAN","strong":"G3007"},{"text":", y","morph":"CLN","strong":"G2532"},{"text":"designaras","morph":"VAAS2S","strong":"G2525"},{"text":"ancianos","morph":"JAPM","strong":"G4245"},{"text":"en cada","morph":"P","strong":"G2596"},{"text":"ciudad","morph":"NASF","strong":"G4172"},{"text":"como","morph":"CAM","strong":"G5613"},{"text":"•","morph":"RP1NS","strong":"G1473"},{"text":"te","morph":"RP2DS","strong":"G4671"},{"text":"mandé","morph":"VAMI1S","strong":"G1299"},{"text":","}]},"6":{"text":"esto es, si alguno es irreprensible, marido de una sola mujer, que tenga hijos creyentes, no acusados de disolución ni de rebeldía.","segments":[{"text":"esto es, si","morph":"CAC","strong":"G1487"},{"text":"alguno","morph":"RX-NSM","strong":"G5100"},{"text":"es","morph":"VPAI3S","strong":"G2076"},{"text":"irreprensible","morph":"JNSM","strong":"G410"},{"text":", marido","morph":"NNSM","strong":"G435"},{"text":"de una","morph":"JGSF","strong":"G1520"},{"text":"sola mujer","morph":"NGSF","strong":"G1135"},{"text":", que tenga","morph":"VPAP-SNM","strong":"G2192"},{"text":"hijos","morph":"NAPN","strong":"G5043"},{"text":"creyentes","morph":"JAPN","strong":"G4103"},{"text":", no","morph":"BN"},{"text":"acusados","morph":"P"},{"text":"de disolución","morph":"NGSF","strong":"G810"},{"text":"ni","morph":"CLD","strong":"G2228"},{"text":"de rebeldía","morph":"JAPN","strong":"G506"},{"text":"."}]},"7":{"text":"Porque el obispo debe ser irreprensible como administrador de Dios, no obstinado, no iracundo, no dado a la bebida, no pendenciero, no amante de ganancias deshonestas,","segments":[{"text":"Porque","morph":"CLX","strong":"G1063"},{"text":"el","morph":"DASM","strong":"G3588"},{"text":"obispo","morph":"NASM","strong":"G1985"},{"text":"debe","morph":"VPAI3S","strong":"G1163"},{"text":"ser","morph":"VPAN","strong":"G1511"},{"text":"irreprensible","morph":"JASM","strong":"G410"},{"text":"como","morph":"P"},{"text":"administrador","morph":"NASM","strong":"G3623"},{"text":"de Dios","morph":"NGSM","strong":"G2316"},{"text":", no","morph":"BN"},{"text":"obstinado","morph":"JASM","strong":"G829"},{"text":", no","morph":"BN"},{"text":"iracundo","morph":"JASM","strong":"G3711"},{"text":", no","morph":"BN"},{"text":"dado","morph":"JASM","strong":"G3943"},{"text":"a la bebida, no","morph":"BN"},{"text":"pendenciero","morph":"NASM","strong":"G4131"},{"text":", no","morph":"BN"},{"text":"amante","morph":"JASM","strong":"G146"},{"text":"de ganancias deshonestas,"}]},"8":{"text":"sino hospitalario, amante de lo bueno, prudente, justo, santo, dueño de sí mismo,","segments":[{"text":"sino","morph":"CLC","strong":"G235"},{"text":"hospitalario","morph":"JASM","strong":"G5382"},{"text":", amante","morph":"JASM","strong":"G5358"},{"text":"de lo bueno, prudente","morph":"JASM","strong":"G4998"},{"text":", justo","morph":"JASM","strong":"G1342"},{"text":", santo","morph":"JASM","strong":"G3741"},{"text":", dueño","morph":"JASM","strong":"G1468"},{"text":"de sí mismo,"}]},"9":{"text":"reteniendo la palabra fiel que es conforme a la enseñanza, para que sea capaz también de exhortar con sana doctrina y refutar a los que contradicen.","segments":[{"text":"reteniendo","morph":"VPUP-SAM","strong":"G472"},{"text":"la palabra","morph":"NGSM","strong":"G3056"},{"text":"fiel","morph":"JGSM","strong":"G4103"},{"text":"que","morph":"DGSM","strong":"G3588"},{"text":"es conforme","morph":"P","strong":"G2596"},{"text":"a la","morph":"DASF","strong":"G3588"},{"text":"enseñanza","morph":"NASF","strong":"G1322"},{"text":", para","morph":"CAP","strong":"G2443"},{"text":"que sea","morph":"VPAS3S","strong":"G5600"},{"text":"capaz","morph":"JNSM","strong":"G1415"},{"text":"también","morph":"CLK","strong":"G2532"},{"text":"de exhortar","morph":"VPAN","strong":"G3870"},{"text":"con","morph":"P","strong":"G1722"},{"text":"sana","morph":"DDSF"},{"text":"doctrina","morph":"DDSF"},{"text":"y","morph":"CLK"},{"text":"refutar","morph":"VPAN","strong":"G1651"},{"text":"a los","morph":"DAPM","strong":"G3588"},{"text":"que contradicen","morph":"VPAP-PAM","strong":"G483"},{"text":"."}]},"10":{"text":"¶ Porque hay muchos • rebeldes, habladores vanos y engañadores, especialmente los de la circuncisión,","segments":[{"text":"¶ Porque","morph":"CLX","strong":"G1063"},{"text":"hay","morph":"VPAI3P","strong":"G1526"},{"text":"muchos","morph":"JNPM","strong":"G4183"},{"text":"•","morph":"BE"},{"text":"rebeldes","morph":"JNPM","strong":"G506"},{"text":", habladores","morph":"JNPM","strong":"G3151"},{"text":"vanos y","morph":"CLN","strong":"G2532"},{"text":"engañadores","morph":"NNPM","strong":"G5423"},{"text":", especialmente","morph":"BS","strong":"G3122"},{"text":"los","morph":"DNPM","strong":"G3588"},{"text":"de","morph":"P","strong":"G1537"},{"text":"la","morph":"DGSF","strong":"G3588"},{"text":"circuncisión","morph":"NGSF","strong":"G4061"},{"text":","}]},"11":{"text":"a quienes es preciso tapar la boca, porque están trastornando familias enteras, enseñando, por ganancias deshonestas, cosas que no deben.","segments":[{"text":"a quienes","morph":"RR-APM","strong":"G3739"},{"text":"es preciso","morph":"VPAI3S","strong":"G1163"},{"text":"tapar","morph":"VPAN","strong":"G1993"},{"text":"la boca, porque","morph":"RR-NPM","strong":"G3748"},{"text":"están trastornando","morph":"VPAI3P","strong":"G396"},{"text":"familias","morph":"NAPM","strong":"G3624"},{"text":"enteras","morph":"JAPM","strong":"G3650"},{"text":", enseñando","morph":"VPAP-PNM","strong":"G1321"},{"text":", por","morph":"P"},{"text":"ganancias","morph":"NGSN","strong":"G2771"},{"text":"deshonestas","morph":"JGSN","strong":"G150"},{"text":", cosas","morph":"RR-APN","strong":"G3739"},{"text":"que no","morph":"BN"},{"text":"deben","morph":"VPAI3S","strong":"G1163"},{"text":"."}]},"12":{"text":"Uno de ellos, su propio profeta, dijo: Los cretenses son siempre mentirosos, malas bestias, glotones ociosos.","segments":[{"text":"Uno","morph":"RX-NSM","strong":"G5100"},{"text":"de","morph":"P","strong":"G1537"},{"text":"ellos","morph":"RP3GPM","strong":"G846"},{"text":", su","morph":"RP3GPM","strong":"G846"},{"text":"propio","morph":"JNSM","strong":"G2398"},{"text":"profeta","morph":"NNSM","strong":"G4396"},{"text":", dijo","morph":"VAAI3S","strong":"G2036"},{"text":": Los cretenses","morph":"NNPM","strong":"G2912"},{"text":"son siempre","morph":"B","strong":"G104"},{"text":"mentirosos","morph":"NNPM","strong":"G5583"},{"text":", malas","morph":"JNPN","strong":"G2556"},{"text":"bestias","morph":"NNPN","strong":"G2342"},{"text":", glotones","morph":"NNPF","strong":"G1064"},{"text":"ociosos","morph":"JNPF","strong":"G692"},{"text":"."}]},"13":{"text":"Este testimonio es verdadero. Por eso, repréndelos severamente para que sean sanos en la fe,","segments":[{"text":"Este","morph":"RD-NSF","strong":"G3778"},{"text":"testimonio","morph":"DNSF"},{"text":"es","morph":"VPAI3S","strong":"G2076"},{"text":"verdadero","morph":"JNSF","strong":"G227"},{"text":". Por","morph":"P","strong":"G1223"},{"text":"eso","morph":"RR-ASF"},{"text":", repréndelos","morph":"VPAM2S"},{"text":"severamente","morph":"B","strong":"G664"},{"text":"para","morph":"CAP","strong":"G2443"},{"text":"que sean sanos","morph":"VPAS3P","strong":"G5198"},{"text":"en","morph":"P","strong":"G1722"},{"text":"la","morph":"DDSF","strong":"G3588"},{"text":"fe","morph":"NDSF","strong":"G4102"},{"text":","}]},"14":{"text":"no prestando atención a mitos judaicos y a mandamientos de hombres que se apartan de la verdad.","segments":[{"text":"no","morph":"BN"},{"text":"prestando","morph":"VPAP-PNM","strong":"G4337"},{"text":"atención a mitos","morph":"NDPM","strong":"G3454"},{"text":"judaicos","morph":"JDPM","strong":"G2451"},{"text":"y","morph":"CLN","strong":"G2532"},{"text":"a mandamientos","morph":"NDPF","strong":"G1785"},{"text":"de hombres","morph":"NGPM","strong":"G444"},{"text":"que se apartan","morph":"VPMP-PGM","strong":"G654"},{"text":"de la","morph":"DASF","strong":"G3588"},{"text":"verdad","morph":"NASF","strong":"G225"},{"text":"."}]},"15":{"text":"Todas las cosas son puras para los puros, mas para los corrompidos e incrédulos nada es puro, sino que tanto su mente como su conciencia están corrompidas.","segments":[{"text":"Todas","morph":"JNPN","strong":"G3956"},{"text":"las cosas son puras","morph":"JNPN","strong":"G2513"},{"text":"para los","morph":"DDPM","strong":"G3588"},{"text":"puros","morph":"JDPM","strong":"G2513"},{"text":", mas","morph":"CLC","strong":"G1161"},{"text":"para los","morph":"DDPM","strong":"G3588"},{"text":"corrompidos","morph":"VRPP-PDM","strong":"G3392"},{"text":"e","morph":"CLN","strong":"G2532"},{"text":"incrédulos","morph":"JDPM","strong":"G571"},{"text":"nada","morph":"JNSN","strong":"G3762"},{"text":"es puro","morph":"JNSN","strong":"G2513"},{"text":", sino","morph":"CLC","strong":"G235"},{"text":"que tanto","morph":"CLK","strong":"G2532"},{"text":"su","morph":"RP3GPM","strong":"G846"},{"text":"mente","morph":"DNSM"},{"text":"como","morph":"CLK"},{"text":"su conciencia","morph":"DNSF"},{"text":"están corrompidas","morph":"VRPI3S","strong":"G3392"},{"text":"."}]},"16":{"text":"Profesan conocer a Dios, pero con sus hechos lo niegan, siendo abominables y desobedientes e inútiles para cualquier obra buena.","segments":[{"text":"Profesan","morph":"VPAI3P","strong":"G3670"},{"text":"conocer","morph":"VRAN","strong":"G1492"},{"text":"a Dios","morph":"NASM","strong":"G2316"},{"text":", pero","morph":"CLC","strong":"G1161"},{"text":"con sus hechos","morph":"DDPN"},{"text":"lo niegan","morph":"VPUI3P","strong":"G720"},{"text":", siendo","morph":"VPAP-PNM","strong":"G5607"},{"text":"abominables","morph":"JNPM","strong":"G947"},{"text":"y","morph":"CLN","strong":"G2532"},{"text":"desobedientes","morph":"JNPM","strong":"G545"},{"text":"e","morph":"CLN","strong":"G2532"},{"text":"inútiles","morph":"JNPM","strong":"G96"},{"text":"para","morph":"P","strong":"G4314"},{"text":"cualquier","morph":"JASN","strong":"G3956"},{"text":"obra","morph":"NASN","strong":"G2041"},{"text":"buena","morph":"JASN","strong":"G18"},{"text":"."}]}},"2":{"1":{"text":"Pero en cuanto a ti, enseña lo que está de acuerdo con la sana doctrina.","segments":[{"text":"Pero","morph":"CLC","strong":"G1161"},{"text":"en cuanto a ti","morph":"RP2NS","strong":"G4771"},{"text":", enseña","morph":"VPAM2S","strong":"G2980"},{"text":"lo que","morph":"RR-APN","strong":"G3739"},{"text":"está de acuerdo","morph":"VPAI3S","strong":"G4241"},{"text":"con la","morph":"DDSF","strong":"G3588"},{"text":"sana","morph":"VPAP-SDF","strong":"G5198"},{"text":"doctrina","morph":"NDSF","strong":"G1319"},{"text":"."}]},"2":{"text":"Los ancianos deben ser sobrios, dignos, prudentes, sanos en la fe, en el amor, en la perseverancia.","segments":[{"text":"Los ancianos","morph":"NAPM","strong":"G4246"},{"text":"deben ser","morph":"VPAN","strong":"G1511"},{"text":"sobrios","morph":"JAPM","strong":"G3524"},{"text":", dignos","morph":"JAPM","strong":"G4586"},{"text":", prudentes","morph":"JAPM","strong":"G4998"},{"text":", sanos","morph":"VPAP-PAM","strong":"G5198"},{"text":"en la","morph":"DDSF","strong":"G3588"},{"text":"fe","morph":"NDSF","strong":"G4102"},{"text":", en el","morph":"DDSF","strong":"G3588"},{"text":"amor","morph":"NDSF","strong":"G26"},{"text":", en la","morph":"DDSF","strong":"G3588"},{"text":"perseverancia","morph":"NDSF","strong":"G5281"},{"text":"."}]},"3":{"text":"Asimismo, las ancianas deben ser reverentes en su conducta: no calumniadoras ni esclavas de mucho vino, que enseñen lo bueno,","segments":[{"text":"Asimismo","morph":"B","strong":"G5615"},{"text":", las ancianas","morph":"NAPF","strong":"G4247"},{"text":"deben ser reverentes","morph":"JAPF","strong":"G2412"},{"text":"en","morph":"P","strong":"G1722"},{"text":"su conducta","morph":"NDSN","strong":"G2688"},{"text":": no","morph":"BN"},{"text":"calumniadoras","morph":"JAPF","strong":"G1228"},{"text":"ni","morph":"BN"},{"text":"esclavas","morph":"VRPP-PAF","strong":"G1402"},{"text":"de mucho","morph":"JDSM","strong":"G4183"},{"text":"vino","morph":"NDSM","strong":"G3631"},{"text":", que enseñen","morph":"JAPF","strong":"G2567"},{"text":"lo bueno,"}]},"4":{"text":"que enseñen a las jóvenes a que amen a sus maridos, a que amen a sus hijos,","segments":[{"text":"que","morph":"CAP","strong":"G2443"},{"text":"enseñen","morph":"VPAS3P","strong":"G4994"},{"text":"a las","morph":"DAPF","strong":"G3588"},{"text":"jóvenes","morph":"JAPF","strong":"G3501"},{"text":"a que amen","morph":"JAPF"},{"text":"a sus maridos,","morph":"VPAN","strong":"G1511"},{"text":"a que amen","morph":"JAPF","strong":"G5388"},{"text":"a sus hijos,"}]},"5":{"text":"a ser prudentes, puras, hacendosas en el hogar, amables, sujetas a sus maridos, para que la palabra de Dios no sea blasfemada.","segments":[{"text":"a ser prudentes","morph":"JAPF","strong":"G4998"},{"text":", puras","morph":"JAPF","strong":"G53"},{"text":", hacendosas en el hogar","morph":"JAPF","strong":"G3626"},{"text":", amables","morph":"JAPF","strong":"G18"},{"text":", sujetas","morph":"VPPP-PAF","strong":"G5293"},{"text":"a sus","morph":"DDPM"},{"text":"maridos","morph":"NDPM","strong":"G435"},{"text":", para","morph":"CAP","strong":"G2443"},{"text":"que la","morph":"DNSM","strong":"G3588"},{"text":"palabra","morph":"NNSM","strong":"G3056"},{"text":"de Dios","morph":"DGSM"},{"text":"no","morph":"BN"},{"text":"sea blasfemada","morph":"VPPS3S","strong":"G987"},{"text":"."}]},"6":{"text":"Asimismo, exhorta a los jóvenes a que sean prudentes;","segments":[{"text":"Asimismo","morph":"B","strong":"G5615"},{"text":", exhorta","morph":"VPAM2S","strong":"G3870"},{"text":"a los","morph":"DAPM","strong":"G3588"},{"text":"jóvenes","morph":"JAPMC","strong":"G3501"},{"text":"a que sean prudentes","morph":"VPAN","strong":"G4993"},{"text":";"}]},"7":{"text":"muéstrate en todo como ejemplo de buenas obras, con pureza de doctrina, con dignidad,","segments":[{"text":"muéstrate","morph":"RF2ASM"},{"text":"en","morph":"P","strong":"G4012"},{"text":"todo","morph":"JAPN","strong":"G3956"},{"text":"como ejemplo","morph":"NASM","strong":"G5179"},{"text":"de buenas","morph":"JGPN","strong":"G2570"},{"text":"obras","morph":"NGPN","strong":"G2041"},{"text":", con pureza","morph":"NASF","strong":"G90"},{"text":"de","morph":"P","strong":"G1722"},{"text":"doctrina","morph":"DDSF"},{"text":", con dignidad","morph":"NASF","strong":"G4587"},{"text":","}]},"8":{"text":"con palabra sana e irreprochable, a fin de que el adversario se avergüence al no tener nada malo que decir de nosotros.","segments":[{"text":"con palabra","morph":"NASM","strong":"G3056"},{"text":"sana","morph":"JASM","strong":"G5199"},{"text":"e irreprochable","morph":"JASM","strong":"G176"},{"text":", a","morph":"CAP","strong":"G2443"},{"text":"fin de que el","morph":"DNSM","strong":"G3588"},{"text":"adversario","morph":"P"},{"text":"se avergüence","morph":"VAPS3S","strong":"G1788"},{"text":"al no tener","morph":"VPAP-SNM","strong":"G2192"},{"text":"nada","morph":"JASN","strong":"G3367"},{"text":"malo","morph":"JASN","strong":"G5337"},{"text":"que decir","morph":"VPAN","strong":"G3004"},{"text":"de","morph":"P","strong":"G4012"},{"text":"nosotros","morph":"RP1GP","strong":"G2257"},{"text":"."}]},"9":{"text":"Exhorta a los siervos a que se sujeten a sus amos en todo, que sean complacientes, no contradiciendo,","segments":[{"text":"Exhorta a los siervos","morph":"NAPM","strong":"G1401"},{"text":"a que se sujeten","morph":"VPPN"},{"text":"a sus","morph":"JDPM","strong":"G2398"},{"text":"amos","morph":"NDPM","strong":"G1203"},{"text":"en","morph":"P","strong":"G1722"},{"text":"todo","morph":"JDPN","strong":"G3956"},{"text":", qu