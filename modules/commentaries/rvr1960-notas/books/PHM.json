{"schemaVersion":1,"book":"PHM","entries":[{"id":"rvr1960-notas-5051","title":"Filemón 1:1–3","author":"Sociedades Bíblicas Unidas / EBH","reference":{"book":"PHM","chapterStart":1,"verseStart":1,"chapterEnd":1,"verseEnd":3},"content":"<p><b><i>Tema:</i></b></p><p><b>Salutación</b></p>"},{"id":"rvr1960-notas-5052","title":"Filemón 1:2","author":"Sociedades Bíblicas Unidas / EBH","reference":{"book":"PHM","chapterStart":1,"verseStart":2,"chapterEnd":1,"verseEnd":2},"content":"<p>y a la amada hermana Apia, y a Arquipo<span style=\"color: #804db3\"><i><span ><sup>a</sup></span></i></span> nuestro compañero de milicia, y a la iglesia que está en tu casa:</p><p><span style=\"color: #804db3\"><i><span ><sup>a</sup></span></i></span> <a class='bible' href='#b51.4.17'>Col 4:17</a>.</p>"},{"id":"rvr1960-notas-5053","title":"Filemón 1:4–7","author":"Sociedades Bíblicas Unidas / EBH","reference":{"book":"PHM","chapterStart":1,"verseStart":4,"chapterEnd":1,"verseEnd":7},"content":"<p><b><i>Tema:</i></b></p><p><b>El amor y la fe de Filemón</b></p>"},{"id":"rvr1960-notas-5054","title":"Filemón 1:8–22","author":"Sociedades Bíblicas Unidas / EBH","reference":{"book":"PHM","chapterStart":1,"verseStart":8,"chapterEnd":1,"verseEnd":22},"content":"<p><b><i>Tema:</i></b></p><p><b>Pablo intercede por Onésimo</b></p>"},{"id":"rvr1960-notas-5055","title":"Filemón 1:10","author":"Sociedades Bíblicas Unidas / EBH","reference":{"book":"PHM","chapterStart":1,"verseStart":10,"chapterEnd":1,"verseEnd":10},"content":"<p>te ruego por mi hijo Onésimo,<span style=\"color: #804db3\"><i><span ><sup>1</sup></span></i></span> <span style=\"color: #804db3\"><i><span ><sup>b</sup></span></i></span> a quien engendré en mis prisiones,</p><p><span style=\"color: #804db3\"><i><span ><sup>1</sup></span></i></span> Esto es, <i>útil</i> (v. 11) o <i>provechoso</i> (v. 20).</p><p><span style=\"color: #804db3\"><i><span ><sup>b</sup></span></i></span> <a class='bible' href='#b51.4.9'>Col 4:9</a>.</p>"},{"id":"rvr1960-notas-5056","title":"Filemón 1:23","author":"Sociedades Bíblicas Unidas / EBH","reference":{"book":"PHM","chapterStart":1,"verseStart":23,"chapterEnd":1,"verseEnd":23},"content":"<p>Te saludan Epafras,<span style=\"color: #804db3\"><i><span ><sup>c</sup></span></i></span> mi compañero de prisiones por Cristo Jesús,</p><p><span style=\"color: #804db3\"><i><span ><sup>c</sup></span></i></span> <a class='bible' href='#b51.1.7'>Col 1:7</a>; <a class='bible' href='#b51.4.12'>Col 4:12</a>.</p>"},{"id":"rvr1960-notas-5057","title":"Filemón 1:23–25","author":"Sociedades Bíblicas Unidas / EBH","reference":{"book":"PHM","chapterStart":1,"verseStart":23,"chapterEnd":1,"verseEnd":25},"content":"<p><b><i>Tema:</i></b></p><p><b>Salutaciones y bendición final</b></p>"},{"id":"rvr1960-notas-5058","title":"Filemón 1:24","author":"Sociedades Bíblicas Unidas / EBH","reference":{"book":"PHM","chapterStart":1,"verseStart":24,"chapterEnd":1,"verseEnd":24},"content":"<p>Marcos,<span style=\"color: #804db3\"><i><span ><sup>d</sup></span></i></span> Aristarco,<span style=\"color: #804db3\"><i><span ><sup>e</sup></span></i></span> Demas<span style=\"color: #804db3\"><i><span ><sup>f</sup></span></i></span> y Lucas,<span style=\"color: #804db3\"><i><span ><sup>g</sup></span></i></span> mis colaboradores.</p><p><span style=\"color: #804db3\"><i><span ><sup>d</sup></span></i></span> <a class='bible' href='#b44.12.12'>Hch 12:12</a>; <a class='bible' href='#b44.12.25'>Hch 12:25</a>; <a class='bible' href='#b44.13.13'>Hch 13:13</a>; <a class='bible' href='#b44.15.37-39'>Hch 15:37-39</a>; <a class='bible' href='#b51.4.10'>Col 4:10</a>.</p><p><span style=\"color: #804db3\"><i><span ><sup>e</sup></span></i></span> <a class='bible' href='#b44.19.29'>Hch 19:29</a>; <a class='bible' href='#b44.27.2'>Hch 27:2</a>; <a class='bible' href='#b51.4.10'>Col 4:10</a>.</p><p><span style=\"color: #804db3\"><i><span ><sup>f</sup></span></i></span> <a class='bible' href='#b51.4.14'>Col 4:14</a>; <a class='bible' href='#b55.4.10'>2Ti 4:10</a>.</p><p><span style=\"color: #804db3\"><i><span ><sup>g</sup></span></i></span> <a class='bible' href='#b51.4.14'>Col 4:14</a>; <a class='bible' href='#b55.4.11'>2Ti 4:11</a>.</p>"}]}