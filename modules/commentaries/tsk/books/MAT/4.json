{"entries":[{"id":"tsk-mat-4-4","title":"Matthew 4:4","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":4,"verseStart":4,"chapterEnd":4,"verseEnd":4},"content":"<p>Follow. 8:22; 9:9; 16:24; 19:21; Mr 2:14; Lu 5:27; 9:59; Joh 1:43; 12:26 Joh 21:22 I will. Eze 47:9,10; Mr 1:17,18; Lu 5:10,11; 1Co 9:20-22; 2Co 12:16</p>"},{"id":"tsk-mat-4-9","title":"Matthew 4:9","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":4,"verseStart":9,"chapterEnd":4,"verseEnd":9},"content":"<p>followed. 5:1; 8:1; 12:15; 19:2; Mr 3:7; 6:2; Lu 6:17,19 Decapolis. Mr 5:20; 7:31</p>"},{"id":"tsk-mat-4-14","title":"Matthew 4:14","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":4,"verseStart":14,"chapterEnd":4,"verseEnd":14},"content":"<p>the meek. 11:29; 21:5; Nu 12:3; Ps 22:26; 25:9; 69:32; *marg: Ps 147:6; 149:4; Isa 11:4; 29:19; 61:1; Zep 2:3; Ga 5:23; Eph 4:2 Col 3:12; 1Ti 6:11; 2Ti 2:25; Tit 3:2; Jas 1:21; 3:13; 1Pe 3:4,15 they. Ps 25:13; 37:9,11,22,29,34; Isa 60:21; Ro 4:13</p>"},{"id":"tsk-mat-4-19","title":"Matthew 4:19","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":4,"verseStart":19,"chapterEnd":4,"verseEnd":19},"content":"<p>when. 10:25; 27:39; Ps 35:11; Isa 66:5; Lu 7:33,34; Joh 9:28; 1Pe 2:23 falsely. Gr. lying. 1Pe 4:14 for. 10:18,22,39; 19:29; 24:9; Ps 44:22; Mr 4:17; 8:35; 13:9,13 Lu 6:22; 9:24; 21:12,17; Joh 15:21; Ac 9:16; Ro 8:36; 1Co 4:10 2Co 4:11; Re 2:3</p>"},{"id":"tsk-mat-4-24","title":"Matthew 4:24","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":4,"verseStart":24,"chapterEnd":4,"verseEnd":24},"content":"<p>to destroy the law. Lu 16:17; Joh 8:5; Ac 6:13; 18:13; 21:28; Ro 3:31; 10:4; Ga 3:17-24 but. 3:15; Ps 40:6-8; Isa 42:21; Ro 8:4; Ga 4:4,5; Col 2:16,17 Heb 10:3-12</p>"}]}