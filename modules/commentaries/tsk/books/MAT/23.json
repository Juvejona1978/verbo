{"entries":[{"id":"tsk-mat-23-1","title":"Matthew 23:1","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":23,"verseStart":1,"chapterEnd":23,"verseEnd":1},"content":"<p>Mr 14:19,20; Lu 22:23; Joh 13:22-25; 21:17</p>"},{"id":"tsk-mat-23-6","title":"Matthew 23:6","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":23,"verseStart":6,"chapterEnd":23,"verseEnd":6},"content":"<p>my. Ex 24:7,8; Le 17:11; Jer 31:31; Zec 9:11; Mr 14:24; Lu 22:19 1Co 11:25; Heb 9:14-22; 10:4-14; 13:20 shed. 20:28; Ro 5:15,19; Eph 1:7; Col 1:14,20; Heb 9:22,28; 1Jo 2:2 Re 7:9,14</p>"},{"id":"tsk-mat-23-11","title":"Matthew 23:11","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":23,"verseStart":11,"chapterEnd":23,"verseEnd":11},"content":"<p>That. Mr 14:30,31; Lu 22:34; Joh 13:38</p>"},{"id":"tsk-mat-23-16","title":"Matthew 23:16","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":23,"verseStart":16,"chapterEnd":23,"verseEnd":16},"content":"<p>and findeth. 43; 25:5; So 5:2; Mr 14:37; Lu 9:32; 22:45 What. 35; Jud 9:33; 1Sa 26:15,16; 1Ki 20:11</p>"},{"id":"tsk-mat-23-21","title":"Matthew 23:21","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":23,"verseStart":21,"chapterEnd":23,"verseEnd":21},"content":"<p>1Sa 17:48; Lu 9:51; 12:50; 22:15; Joh 14:31; Ac 21:13</p>"},{"id":"tsk-mat-23-26","title":"Matthew 23:26","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":23,"verseStart":26,"chapterEnd":23,"verseEnd":26},"content":"<p>Put. 5:39; Ro 12:19; 1Co 4:11,12; 1Th 5:15; 1Pe 2:21-23; 3:9 they. 23:34-36; Ge 9:6; Ps 55:23; Eze 35:5,6; Re 13:10; 16:6</p>"},{"id":"tsk-mat-23-31","title":"Matthew 23:31","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":23,"verseStart":31,"chapterEnd":23,"verseEnd":31},"content":"<p>and went. Joh 18:15,16,25</p>"},{"id":"tsk-mat-23-36","title":"Matthew 23:36","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":23,"verseStart":36,"chapterEnd":23,"verseEnd":36},"content":"<p>Thou. 25; 27:11; Mr 14:62; Lu 22:70; Joh 18:37 Hereafter. 16:27; 24:30; 25:31; Da 7:13; Lu 21:27; Joh 1:50,51; Ac 1:11 Ro 14:10; 1Th 4:16; Re 1:7; 20:11 the right. Ps 110:1; Ac 7:55,56; Heb 1:3; 12:2</p>"}]}