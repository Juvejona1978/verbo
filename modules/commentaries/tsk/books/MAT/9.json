{"entries":[{"id":"tsk-mat-9-4","title":"Matthew 9:4","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":9,"verseStart":4,"chapterEnd":9,"verseEnd":4},"content":"<p>verily. 5:18; 24:34,35 It. 11:22-24; Eze 16:48-56; Mr 6:11; Lu 10:11,12; Joh 15:22-24 in the. 12:36; 2Pe 2:9; 3:7; 1Jo 4:17</p>"},{"id":"tsk-mat-9-9","title":"Matthew 9:9","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":9,"verseStart":9,"chapterEnd":9,"verseEnd":9},"content":"<p>the brother shall. 34-36; 24:10; Mic 7:5,6; Zec 13:3; Mr 13:12,13; Lu 12:51-53 Lu 21:16,17 the children. 2Sa 16:11; 17:1-4; Job 19:19</p>"},{"id":"tsk-mat-9-14","title":"Matthew 9:14","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":9,"verseStart":14,"chapterEnd":9,"verseEnd":14},"content":"<p>I tell. 13:1-17,34,35; Lu 8:10; Joh 16:1,13,25,29; 2Co 3:12 that preach. Pr 1:20-23; 8:1-5; Ac 5:20,28; 17:17</p>"},{"id":"tsk-mat-9-19","title":"Matthew 9:19","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":9,"verseStart":19,"chapterEnd":9,"verseEnd":19},"content":"<p>deny me. 26:70-75; Mr 14:30,72; Lu 9:26; 12:9; 2Ti 2:12; 2Pe 2:1; 1Jo 2:23</p>"},{"id":"tsk-mat-9-24","title":"Matthew 9:24","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":9,"verseStart":24,"chapterEnd":9,"verseEnd":24},"content":"<p>16:25,26; Mr 8:35,36; Lu 17:33; Joh 12:25; Php 1:20,21 2Ti 4:6-8; Re 2:10</p>"},{"id":"tsk-mat-9-29","title":"Matthew 9:29","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":9,"verseStart":29,"chapterEnd":9,"verseEnd":29},"content":"<p>in. 4:12; 14:3; Mr 6:17; Lu 3:19; 7:18-23; Joh 3:24 he. 9:14; Joh 3:25-28; 4:1; Ac 19:1-3</p>"},{"id":"tsk-mat-9-34","title":"Matthew 9:34","author":"R. A. Torrey (editor)","reference":{"book":"MAT","chapterStart":9,"verseStart":34,"chapterEnd":9,"verseEnd":34},"content":"<p>A man. 3:4; 2Ki 1:8; Isa 20:2; Zec 13:4; 1Co 4:11; 2Co 11:27; Re 11:3</p>"}]}