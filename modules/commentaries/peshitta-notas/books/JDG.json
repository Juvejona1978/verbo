n><span style=\"\" lang=\"es-ES\">etc. Se caracterizaba principalmente por el sacrificio de niños primogénitos pasados por fuego.</span></p><span style=\"color:#0000FF;\"></span></p><span style=\"color:#0000FF;font-weight:bold;text-decoration:underline;\"><sup>a</sup></span> </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b4.25.1-3'>Núm 25:1-3</a></span>; </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b7.3.7'>Jue 3:7</a></span>; </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b7.10.6'>Jue 10:6</a></span></p></span></p>"},{"id":"peshitta-notas-1033","title":"Jueces 2:13","author":"Instituto Cultural Álef y Tau, A.C.","reference":{"book":"JDG","chapterStart":2,"verseStart":13,"chapterEnd":2,"verseEnd":13},"content":"<span style=\"color:#0000FF;font-weight:bold;text-decoration:underline;\"><sup>a</sup></span> </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b7.3.7'>Jue 3:7</a></span>; </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b7.10.6'>Jue 10:6</a></span>; </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b11.11.5'>1Re 11:5</a></span></p></span></p>"},{"id":"peshitta-notas-1034","title":"Jueces 2:14","author":"Instituto Cultural Álef y Tau, A.C.","reference":{"book":"JDG","chapterStart":2,"verseStart":14,"chapterEnd":2,"verseEnd":14},"content":"<span style=\"color:#0000FF;font-weight:bold;text-decoration:underline;\"><sup>a</sup></span> </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b5.28.25'>Deu 28:25</a></span>; </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b5.32.30'>Deu 32:30</a></span>; </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b19.106.40-42'>Sal 106:40-42</a></span></p></span></p>"