{"schemaVersion":1,"book":"OBA","entries":[{"id":"peshitta-notas-3475","title":"Abdías 0:0–1","author":"Instituto Cultural Álef y Tau, A.C.","reference":{"book":"OBA","chapterStart":0,"verseStart":0,"chapterEnd":0,"verseEnd":1},"content":"<p lang=\"es-ES\" style=\"text-align:center;text-indent:0pt;margin-left:0pt;margin-top:6pt;margin-bottom:6pt;margin-right:2pt;line-height:16pt;\"><span style=\"font-size:24pt;font-weight:bold;\">LIBRO DEL PROFETA</span></p><p lang=\"es-ES\" style=\"text-align:center;text-indent:0pt;margin-left:0pt;margin-top:3pt;margin-bottom:12pt;margin-right:0pt;line-height:23pt;\"><span style=\"font-size:24pt;font-weight:bold;\">ABDÍAS</span></p><p lang=\"es-ES\" style=\"text-align:justify;text-indent:0pt;margin-left:0pt;margin-top:3pt;margin-bottom:12pt;margin-right:0pt;line-height:14pt;\"><span style=\"\">Aram., </span><span style=\"font-style:italic;\">Ketava d’Obadya Nebya</span><span style=\"\">. Se traduce </span><span style=\"font-style:italic;\">Libro del Profeta Abdías. </span><span style=\"\">Heb., </span><span style=\"font-style:italic;\">Obadyah. </span><span style=\"\">Abdías significa </span><span style=\"font-style:italic;\">siervo de Yah</span><span style=\"\">. Su autor es el profeta Abdías, y por el contexto histórico en que se desarrollan los eventos mencionados en el libro, su fecha de redacción se sitúa entre los años </span><span style=\"text-decoration:underline;\">840</span><span style=\"\">-</span><span style=\"text-decoration:underline;\">845</span><span style=\"\"> a. C. Es el libro más breve del Antiguo Testamento, pero tal vez fue el primer escrito profético. El libro se introduce como una visión. Se evidencia la histórica rivalidad entre Judá y Edom, fiel manifestación del conflicto entre Jacob y Esaú, antepasados de ambos. Abdías predice la caída de Edom debido a los pecados cometidos contra su pueblo. Se anuncia el día de Yahweh sobre Edom y las naciones, cuando el pueblo de Dios poseerá el territorio de Edom.</span></p><p lang=\"es-ES\" style=\"text-align:justify;text-indent:0pt;margin-left:0pt;margin-top:3pt;margin-bottom:12pt;margin-right:0pt;line-height:14pt;\"></span></p>"},{"id":"peshitta-notas-3476","title":"Abdías 1:1","author":"Instituto Cultural Álef y Tau, A.C.","reference":{"book":"OBA","chapterStart":1,"verseStart":1,"chapterEnd":1,"verseEnd":1},"content":"<span style=\"color:#0000FF;font-weight:bold;text-decoration:underline;\"><sup>a</sup></span> </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b5.10.17'>Deu 10:17</a></span>; </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b13.16.36'>1Cr 16:36</a></span>; </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b19.136.3'>Sal 136:3</a></span>; </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b33.1.2'>Miq 1:2</a></span></p></span></p>"},{"id":"peshitta-notas-3477","title":"Abdías 1:3","author":"Instituto Cultural Álef y Tau, A.C.","reference":{"book":"OBA","chapterStart":1,"verseStart":3,"chapterEnd":1,"verseEnd":3},"content":"<span style=\"color:#0000FF;font-weight:bold;text-decoration:underline;\"><sup>a</sup></span> </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b18.20.4-7'>Job 20:4-7</a></span>; </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b23.14.12-32'>Isa 14:12-32</a></span><span style=\"color:#008000;\">;</span></p></span></p>"},{"id":"peshitta-notas-3478","title":"Abdías 1:12","author":"Instituto Cultural Álef y Tau, A.C.","reference":{"book":"OBA","chapterStart":1,"verseStart":12,"chapterEnd":1,"verseEnd":12},"content":"<span style=\"color:#0000FF;font-weight:bold;text-decoration:underline;\"><sup>1</sup></span> Lit., </span><span style=\"font-style:italic;\">veas</span>.</span></p></span></p><span style=\"color:#0000FF;font-weight:bold;text-decoration:underline;\"><sup>a</sup></span> </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b20.17.5'>Pro 17:5</a></span>; </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b26.35.15'>Eze 35:15</a></span> </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b26.36.5'>Eze 36:5</a></span></p></span></p>"},{"id":"peshitta-notas-3480","title":"Abdías 1:15","author":"Instituto Cultural Álef y Tau, A.C.","reference":{"book":"OBA","chapterStart":1,"verseStart":15,"chapterEnd":1,"verseEnd":15},"content":"<span style=\"color:#0000FF;font-weight:bold;text-decoration:underline;\"><sup>a</sup></span> </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b30.5.18'>Amó 5:18</a></span>; </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b29.1.15'>Joe 1:15</a></span></p></span></p>"},{"id":"peshitta-notas-3481","title":"Abdías 1:21","author":"Instituto Cultural Álef y Tau, A.C.","reference":{"book":"OBA","chapterStart":1,"verseStart":21,"chapterEnd":1,"verseEnd":21},"content":"<span style=\"color:#0000FF;font-weight:bold;text-decoration:underline;\"><sup>a</sup></span> </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b19.47.7-8'>Sal 47:7-8</a></span>; </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b38.14.9'>Zac 14:9</a></span>; </span><span style=\"color:#008000;text-decoration:underline;\"><a class=\"bible\" href='#b40.6.13'>Mat 6:13</a></span></p></span></p>"}]}